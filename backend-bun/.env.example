# Server
PORT=9090
HOST=0.0.0.0
NODE_ENV=development

# Security
# IMPORTANT: Change these to strong random values in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-strong-random-value-in-production
API_KEY=change-this-to-a-strong-random-value-in-production

# CORS: Allow all since this is internal only
CORS_ORIGIN=*

# Database
DB_PATH=./data/wagateway.db

# Anti-Block
ANTIBLOCK_ENABLED=true
RATE_LIMIT_ENABLED=true
MESSAGES_PER_MINUTE=5
MESSAGES_PER_HOUR=50
BURST_LIMIT=10

DELAY_ENABLED=true
MIN_DELAY=1
MAX_DELAY=5

WARMUP_ENABLED=true
WARMUP_DAYS=7

# Webhook
WEBHOOK_RETRIES=3
WEBHOOK_TIMEOUT=30000

# AI Integration (Kimi/Moonshot)
# Get API key from: https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
# Available models: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
